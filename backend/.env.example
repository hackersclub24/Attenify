# ─────────────────────────────────────────
# Attenify Backend — Environment Variables
# ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit your actual .env file to version control.

# ── Database ──────────────────────────────
# Async PostgreSQL connection string
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/attenify

# ── JWT Authentication ────────────────────
# A long, random secret string (use: openssl rand -hex 32)
SECRET_KEY=your_super_secret_key_here

# Signing algorithm (HS256 recommended)
ALGORITHM=HS256

# Token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60
